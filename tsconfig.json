{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"allowJs": false,
		"isolatedModules": true,
		"verbatimModuleSyntax": true,
		"noEmit": true,
		"strict": false,
		"lib": ["ES2022", "DOM", "DOM.Iterable"],
		"types": ["chrome", "node"]
	},
	"include": [
		"src/**/*.ts",
		"src/**/*.d.ts",
		"src/**/*.svelte",
		"vite.config.ts",
		"service-worker.ts",
		"lib/**/*.ts"
	]
}